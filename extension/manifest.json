{
  "manifest_version": 3,
  "name": "Timesheet CSV Autofill",
  "version": "1.0.0",
  "description": "Paste a day's CSV from Time Tracker and auto-fill the Techzu Fillout daily timesheet form.",
  "permissions": ["storage", "scripting", "tabs", "clipboardRead"],
  "host_permissions": ["https://techzu.fillout.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Timesheet CSV Autofill",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
